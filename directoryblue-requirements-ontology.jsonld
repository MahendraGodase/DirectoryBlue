  "@graph": [
    {
      "@id": "MODULE_001",
      "@type": "SoftwareModule",
      "title": "DirectoryBlue Search Inventory",
      "description": "Search and manage provider inventory tasks",
      "version": "1.0.0",
      "status": "Active"
    },
    {
      "@id": "REQ_FUNC_001",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_001",
      "title": "Search by NPI",
      "description": "System shall allow users to search inventory by National Provider Identifier (NPI)",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "User can enter NPI and retrieve matching provider records",
      "verifiedBy": ["TC_001", "TC_002"]
    },
    {
      "@id": "REQ_FUNC_002",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_002",
      "title": "Search by Data Source",
      "description": "System shall allow users to filter inventory by data source",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "User can select data source from dropdown and filter results",
      "verifiedBy": ["TC_003"]
    },
    {
      "@id": "REQ_FUNC_003",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_003",
