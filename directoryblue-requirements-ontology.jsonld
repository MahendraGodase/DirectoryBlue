    {
      "@id": "REQ_FUNC_010",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_010",
      "title": "Filter by Work Queue",
      "description": "System shall allow users to filter inventory by work queue",
      "priority": "Medium",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "User can select work queue and view queue-specific tasks",
      "verifiedBy": ["TC_012"]
    },
    {
      "@id": "REQ_FUNC_011",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_011",
      "title": "Advanced Search Option",
      "description": "System shall provide an advanced search option with multiple filter combinations",
      "priority": "Medium",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "User can access advanced search and combine multiple filters",
      "verifiedBy": ["TC_013"]
    },
    {
      "@id": "REQ_FUNC_012",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_012",
      "title": "Submit Search Action",
      "description": "System shall execute search when user clicks Submit button",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "Search executes and displays results when Submit is clicked",
      "verifiedBy": ["TC_014"],
      "dependsOn": ["REQ_FUNC_001", "REQ_FUNC_002", "REQ_FUNC_003"]
    },
    {
      "@id": "REQ_FUNC_013",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_013",
      "title": "Clear Filter Action",
      "description": "System shall clear all search filters when user clicks Clear Filter button",
      "priority": "Medium",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "All filters reset to default values when Clear Filter is clicked",
      "verifiedBy": ["TC_015"]
    },
    {
      "@id": "REQ_FUNC_014",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_014",
      "title": "Task Bulk Update",
      "description": "System shall allow users to perform bulk updates on selected tasks",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "User can select multiple tasks and update them simultaneously",
      "verifiedBy": ["TC_016", "TC_017"],
      "dependsOn": ["REQ_FUNC_018"]
    },
    {
      "@id": "REQ_FUNC_015",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_015",
      "title": "Export to Excel",
      "description": "System shall allow users to export search results to Excel format",
      "priority": "Medium",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "User can export current search results to Excel file",
      "verifiedBy": ["TC_018", "TC_019"]
    },
    {
      "@id": "REQ_FUNC_016",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_016",
      "title": "Display Search Results Grid",
      "description": "System shall display search results in a sortable, paginated grid",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "Search results display in grid with sorting and pagination",
      "verifiedBy": ["TC_020"],
      "dependsOn": ["REQ_FUNC_012"]
    },
    {
      "@id": "REQ_FUNC_017",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_017",
      "title": "View Task Details",
      "description": "System shall allow users to view detailed information for selected tasks",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "User can click on task to view full details",
      "verifiedBy": ["TC_021"]
    },
    {
      "@id": "REQ_FUNC_018",
      "@type": "FunctionalRequirement",
      "requirementId": "REQ_FUNC_018",
      "title": "Select Multiple Tasks",
      "description": "System shall allow users to select multiple tasks using checkboxes",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "User can select/deselect individual or all tasks",
      "verifiedBy": ["TC_022"]
    },
    {
      "@id": "REQ_PERF_001",
      "@type": "PerformanceRequirement",
      "requirementId": "REQ_PERF_001",
      "title": "Search Response Time",
      "description": "System shall return search results within 3 seconds for standard queries",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "performanceMetric": "Response Time",
      "targetValue": "< 3 seconds",
      "acceptanceCriteria": "95% of searches complete within 3 seconds",
      "verifiedBy": ["TC_023"]
    },
    {
      "@id": "REQ_PERF_002",
      "@type": "PerformanceRequirement",
      "requirementId": "REQ_PERF_002",
      "title": "Bulk Update Performance",
      "description": "System shall process bulk updates of up to 1000 tasks within 30 seconds",
      "priority": "Medium",
      "status": "Approved",
      "module": "MODULE_001",
      "performanceMetric": "Processing Time",
      "targetValue": "< 30 seconds for 1000 tasks",
      "acceptanceCriteria": "Bulk update completes within specified time",
      "verifiedBy": ["TC_024"]
    },
    {
      "@id": "REQ_PERF_003",
      "@type": "PerformanceRequirement",
      "requirementId": "REQ_PERF_003",
      "title": "Excel Export Performance",
      "description": "System shall export up to 10,000 records to Excel within 10 seconds",
      "priority": "Medium",
      "status": "Approved",
      "module": "MODULE_001",
      "performanceMetric": "Export Time",
      "targetValue": "< 10 seconds for 10,000 records",
      "acceptanceCriteria": "Export completes within specified time",
      "verifiedBy": ["TC_025"]
    },
    {
      "@id": "REQ_SECURITY_001",
      "@type": "SecurityRequirement",
      "requirementId": "REQ_SECURITY_001",
      "title": "User Authentication",
      "description": "System shall require user authentication before accessing search inventory",
      "priority": "Critical",
      "status": "Approved",
      "module": "MODULE_001",
      "securityLevel": "High",
      "acceptanceCriteria": "Only authenticated users can access the system",
      "verifiedBy": ["TC_026"]
    },
    {
      "@id": "REQ_SECURITY_002",
      "@type": "SecurityRequirement",
      "requirementId": "REQ_SECURITY_002",
      "title": "Role-Based Access Control",
      "description": "System shall enforce role-based access control for different user types",
      "priority": "Critical",
      "status": "Approved",
      "module": "MODULE_001",
      "securityLevel": "High",
      "acceptanceCriteria": "Users can only access features authorized for their role",
      "verifiedBy": ["TC_027", "TC_028"],
      "dependsOn": ["REQ_SECURITY_001"]
    },
    {
      "@id": "REQ_SECURITY_003",
      "@type": "SecurityRequirement",
      "requirementId": "REQ_SECURITY_003",
      "title": "Audit Trail",
      "description": "System shall maintain audit trail of all search and update operations",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "securityLevel": "Medium",
      "acceptanceCriteria": "All user actions are logged with timestamp and user ID",
      "verifiedBy": ["TC_029"]
    },
    {
      "@id": "REQ_SECURITY_004",
      "@type": "SecurityRequirement",
      "requirementId": "REQ_SECURITY_004",
      "title": "Data Encryption",
      "description": "System shall encrypt sensitive provider data in transit and at rest",
      "priority": "Critical",
      "status": "Approved",
      "module": "MODULE_001",
      "securityLevel": "High",
      "acceptanceCriteria": "All sensitive data is encrypted using industry standards",
      "verifiedBy": ["TC_030"]
    },
    {
      "@id": "REQ_NONFUNC_001",
      "@type": "NonFunctionalRequirement",
      "requirementId": "REQ_NONFUNC_001",
      "title": "System Availability",
      "description": "System shall maintain 99.9% uptime during business hours",
      "priority": "High",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "System available 99.9% of time during 6 AM - 10 PM EST",
      "verifiedBy": ["TC_031"]
    },
    {
      "@id": "REQ_NONFUNC_002",
      "@type": "NonFunctionalRequirement",
      "requirementId": "REQ_NONFUNC_002",
      "title": "Browser Compatibility",
      "description": "System shall support Chrome, Firefox, Edge, and Safari browsers",
      "priority": "Medium",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "Application functions correctly on specified browsers",
      "verifiedBy": ["TC_032"]
    },
    {
      "@id": "REQ_NONFUNC_003",
      "@type": "NonFunctionalRequirement",
      "requirementId": "REQ_NONFUNC_003",
      "title": "Responsive Design",
      "description": "System shall provide responsive design for different screen sizes",
      "priority": "Medium",
      "status": "Approved",
      "module": "MODULE_001",
      "acceptanceCriteria": "UI adapts to desktop, tablet, and mobile screens",
      "verifiedBy": ["TC_033"]
    },
    {
      "@id": "STAKEHOLDER_001",
      "@type": "Stakeholder",
      "name": "Operations User",
      "role": "EndUser",
      "description": "User who performs daily search and task management operations",
      "responsibilities": ["Search inventory", "Update tasks", "Export reports"]
    },
    {
      "@id": "STAKEHOLDER_002",
      "@type": "Stakeholder",
      "name": "Admin",
      "role": "Administrator",
      "description": "User with administrative privileges for system configuration",
      "responsibilities": ["Manage users", "Configure system", "Monitor performance"]
    },
    {
      "@id": "STAKEHOLDER_003",
      "@type": "Stakeholder",
      "name": "Reporting User",
      "role": "Analyst",
      "description": "User who generates reports and analyzes inventory data",
      "responsibilities": ["Generate reports", "Export data", "Analyze trends"]
    },
    {
      "@id": "GOAL_001",
      "@type": "BusinessGoal",
      "title": "Search Provider Inventory",
      "description": "Enable efficient searching of provider inventory across multiple criteria",
      "priority": "High",
      "satisfiedBy": ["REQ_FUNC_001", "REQ_FUNC_002", "REQ_FUNC_003", "REQ_FUNC_004", "REQ_FUNC_012"]
    },
    {
      "@id": "GOAL_002",
      "@type": "BusinessGoal",
      "title": "Manage Task Queue",
      "description": "Provide comprehensive task queue management capabilities",
      "priority": "High",
      "satisfiedBy": ["REQ_FUNC_007", "REQ_FUNC_008", "REQ_FUNC_009", "REQ_FUNC_010"]
    },
    {
      "@id": "GOAL_003",
      "@type": "BusinessGoal",
      "title": "Bulk Update Tasks",
      "description": "Enable efficient bulk updates of multiple tasks simultaneously",
      "priority": "High",
      "satisfiedBy": ["REQ_FUNC_014", "REQ_FUNC_018"]
    },
    {
      "@id": "GOAL_004",
      "@type": "BusinessGoal",
      "title": "Export Inventory Results",
      "description": "Allow users to export search results for external analysis",
      "priority": "Medium",
      "satisfiedBy": ["REQ_FUNC_015"]
    },
    {
      "@id": "UC_001",
      "@type": "UseCase",
      "useCaseId": "UC_001",
      "title": "Search Tasks by NPI",
      "description": "User searches for provider tasks using NPI",
      "actor": "Operations User",
      "precondition": "User is authenticated and has search permissions",
      "mainFlow": "1. User enters NPI in search field\n2. User clicks Submit\n3. System retrieves matching tasks\n4. System displays results in grid",
      "postcondition": "Search results are displayed",
      "realizedBy": ["REQ_FUNC_001", "REQ_FUNC_012", "REQ_FUNC_016"]
    },
    {
      "@id": "UC_002",
      "@type": "UseCase",
      "useCaseId": "UC_002",
      "title": "Clear Search Filters",
      "description": "User clears all applied search filters",
      "actor": "Operations User",
      "precondition": "User has applied one or more filters",
      "mainFlow": "1. User clicks Clear Filter button\n2. System resets all filter fields\n3. System clears search results",
      "postcondition": "All filters are cleared",
      "realizedBy": ["REQ_FUNC_013"]
    },
    {
      "@id": "UC_003",
      "@type": "UseCase",
      "useCaseId": "UC_003",
      "title": "Bulk Update Selected Tasks",
      "description": "User performs bulk update on multiple selected tasks",
      "actor": "Operations User",
      "precondition": "User has search results displayed",
      "mainFlow": "1. User selects multiple tasks using checkboxes\n2. User clicks Task Bulk Update\n3. System displays bulk update form\n4. User enters update values\n5. User confirms update\n6. System updates all selected tasks",
      "postcondition": "Selected tasks are updated",
      "realizedBy": ["REQ_FUNC_014", "REQ_FUNC_018"]
    },
    {
      "@id": "UC_004",
      "@type": "UseCase",
      "useCaseId": "UC_004",
      "title": "Export Results to Excel",
      "description": "User exports search results to Excel file",
      "actor": "Reporting User",
      "precondition": "User has search results displayed",
      "mainFlow": "1. User clicks Export to Excel button\n2. System generates Excel file\n3. System prompts user to download file\n4. User saves file locally",
      "postcondition": "Excel file is downloaded",
      "realizedBy": ["REQ_FUNC_015"]
    },
    {
      "@id": "UC_005",
      "@type": "UseCase",
      "useCaseId": "UC_005",
      "title": "View Search Results",
      "description": "User views and navigates search results",
      "actor": "Operations User",
      "precondition": "Search has been executed",
      "mainFlow": "1. System displays results in grid\n2. User can sort columns\n3. User can navigate pages\n4. User can select tasks for details",
      "postcondition": "User can interact with results",
      "realizedBy": ["REQ_FUNC_016", "REQ_FUNC_17"]
    },
    {
      "@id": "UC_006",
      "@type": "UseCase",
      "useCaseId": "UC_006",
      "title": "Advanced Search with Multiple Filters",
      "description": "User performs advanced search with multiple filter combinations",
      "actor": "Operations User",
      "precondition": "User is on search inventory page",
      "mainFlow": "1. User clicks Advanced Search\n2. User selects multiple filter criteria\n3. User enters filter values\n4. User clicks Submit\n5. System applies all filters\n6. System displays filtered results",
      "postcondition": "Filtered results are displayed",
      "realizedBy": ["REQ_FUNC_011", "REQ_FUNC_012"]
    },
    {
      "@id": "TC_001",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_001",
      "title": "Verify NPI Search - Valid Input",
      "description": "Test that valid NPI returns correct results",
      "testSteps": "1. Enter valid NPI\n2. Click Submit\n3. Verify results displayed",
      "expectedResult": "Matching provider records are displayed",
      "verifies": "REQ_FUNC_001",
      "status": "Pass"
    },
    {
      "@id": "TC_002",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_002",
      "title": "Verify NPI Search - Invalid Input",
      "description": "Test that invalid NPI shows appropriate message",
      "testSteps": "1. Enter invalid NPI\n2. Click Submit\n3. Verify error message",
      "expectedResult": "Error message displayed, no results shown",
      "verifies": "REQ_FUNC_001",
      "status": "Pass"
    },
    {
      "@id": "TC_003",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_003",
      "title": "Verify Data Source Filter",
      "description": "Test that data source filter works correctly",
      "testSteps": "1. Select data source from dropdown\n2. Click Submit\n3. Verify filtered results",
      "expectedResult": "Only records from selected data source are displayed",
      "verifies": "REQ_FUNC_002",
      "status": "Pass"
    },
    {
      "@id": "TC_004",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_004",
      "title": "Verify Task ID Search",
      "description": "Test that Task ID search returns specific task",
      "testSteps": "1. Enter Task ID\n2. Click Submit\n3. Verify single task displayed",
      "expectedResult": "Specific task with matching ID is displayed",
      "verifies": "REQ_FUNC_003",
      "status": "Pass"
    },
    {
      "@id": "TC_005",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_005",
      "title": "Verify Provider ID Search",
      "description": "Test that Provider ID search returns correct records",
      "testSteps": "1. Enter Provider ID\n2. Click Submit\n3. Verify results",
      "expectedResult": "All tasks for specified provider are displayed",
      "verifies": "REQ_FUNC_004",
      "status": "Pass"
    },
    {
      "@id": "TC_006",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_006",
      "title": "Verify Outbound File Date Range Filter",
      "description": "Test that date range filter works correctly",
      "testSteps": "1. Select start date\n2. Select end date\n3. Click Submit\n4. Verify filtered results",
      "expectedResult": "Only records within date range are displayed",
      "verifies": "REQ_FUNC_005",
      "status": "Pass"
    },
    {
      "@id": "TC_007",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_007",
      "title": "Verify Date Range Validation",
      "description": "Test that invalid date ranges are rejected",
      "testSteps": "1. Enter end date before start date\n2. Click Submit\n3. Verify validation message",
      "expectedResult": "Validation error displayed, search not executed",
      "verifies": "REQ_FUNC_005",
      "status": "Pass"
    },
    {
      "@id": "TC_008",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_008",
      "title": "Verify Corporate Receipt Date Filter",
      "description": "Test corporate receipt date range filtering",
      "testSteps": "1. Select date range\n2. Click Submit\n3. Verify results",
      "expectedResult": "Records within corporate receipt date range displayed",
      "verifies": "REQ_FUNC_006",
      "status": "Pass"
    },
    {
      "@id": "TC_009",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_009",
      "title": "Verify Task Name Filter",
      "description": "Test task name filtering",
      "testSteps": "1. Select task name\n2. Click Submit\n3. Verify filtered results",
      "expectedResult": "Only tasks with selected name are displayed",
      "verifies": "REQ_FUNC_007",
      "status": "Pass"
    },
    {
      "@id": "TC_010",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_010",
      "title": "Verify Task Status Filter",
      "description": "Test task status filtering",
      "testSteps": "1. Select task status\n2. Click Submit\n3. Verify results",
      "expectedResult": "Only tasks with selected status are displayed",
      "verifies": "REQ_FUNC_008",
      "status": "Pass"
    },
    {
      "@id": "TC_011",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_011",
      "title": "Verify Assigned To Filter",
      "description": "Test assigned user filtering",
      "testSteps": "1. Select assigned user\n2. Click Submit\n3. Verify results",
      "expectedResult": "Only tasks assigned to selected user are displayed",
      "verifies": "REQ_FUNC_009",
      "status": "Pass"
    },
    {
      "@id": "TC_012",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_012",
      "title": "Verify Work Queue Filter",
      "description": "Test work queue filtering",
      "testSteps": "1. Select work queue\n2. Click Submit\n3. Verify results",
      "expectedResult": "Only tasks in selected queue are displayed",
      "verifies": "REQ_FUNC_010",
      "status": "Pass"
    },
    {
      "@id": "TC_013",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_013",
      "title": "Verify Advanced Search",
      "description": "Test advanced search with multiple filters",
      "testSteps": "1. Click Advanced Search\n2. Apply multiple filters\n3. Click Submit\n4. Verify results",
      "expectedResult": "Results match all applied filter criteria",
      "verifies": "REQ_FUNC_011",
      "status": "Pass"
    },
    {
      "@id": "TC_014",
      "@type": "AcceptanceTest",
      "testCaseId": "TC_014",
